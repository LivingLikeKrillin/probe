{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/check-scope.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/check-protected-files.sh \"$TOOL_INPUT\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": []
  }
}
